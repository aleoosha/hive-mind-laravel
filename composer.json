{
    "name": "aleoosha/hive-mind-laravel",
    "description": "Biological load balancing and self-regulation for Laravel clusters",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Aleoosha\\HiveMind\\": "src/"
        }
    },
    "authors": [
        {
            "name": "aleoosha"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Aleoosha\\HiveMind\\Providers\\HiveMindServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "require-dev": {
        "pestphp/pest": "^4.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
